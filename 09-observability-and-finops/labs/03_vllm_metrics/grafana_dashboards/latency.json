{
  "__comment": "vLLM 延迟分析 Dashboard — TTFT/TPOT 分位数趋势、延迟分解、异常检测",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "延迟深度剖析：TTFT/TPOT 分位数、E2E 分解、延迟异常检测、SLO 达成率",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Latency SLO Status — SLO 达成状态",
      "type": "row"
    },
    {
      "id": 1,
      "title": "TTFT P50",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "TTFT P50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "TTFT P99",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "TTFT P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "TPOT P50",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "TPOT P50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "TPOT P99",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "TPOT P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "E2E P99",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "E2E P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "TTFT SLO (< 5s) Compliance",
      "description": "TTFT P99 < 5s 的 SLO 达成率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "(1 - (sum(rate(vllm:time_to_first_token_seconds_bucket{le=\"5\", instance=~\"$instance\"}[5m])) / sum(rate(vllm:time_to_first_token_seconds_count{instance=~\"$instance\"}[5m])))) * 100",
          "legendFormat": "SLO Violation %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "TTFT Deep Dive — TTFT 深度分析",
      "type": "row"
    },
    {
      "id": 10,
      "title": "TTFT Percentiles Over Time",
      "description": "TTFT P50/P90/P99/P999 全分位数趋势 — 捕捉尾延迟恶化",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P99"
        },
        {
          "expr": "histogram_quantile(0.999, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P99.9"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "gradientMode": "scheme"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99.9" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.lineStyle", "value": { "fill": "dot" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P90" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 11,
      "title": "TTFT per Instance (P99)",
      "description": "每个实例的 TTFT P99 — 识别哪个实例延迟异常高",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, instance) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "TPOT Deep Dive — TPOT 深度分析",
      "type": "row"
    },
    {
      "id": 20,
      "title": "TPOT Percentiles Over Time",
      "description": "TPOT P50/P90/P99 趋势 — 用户体验的直接衡量 (<30ms 流畅，>100ms 需优化)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 21,
      "title": "TPOT vs Batch Size Correlation",
      "description": "TPOT P99 与 Running 请求数的关联 — batch 越大，TPOT 通常越高",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "TPOT P99 (ms)"
        },
        {
          "expr": "sum(vllm:num_requests_running{instance=~\"$instance\"})",
          "legendFormat": "Running Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TPOT P99 (ms)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "ms" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Running Requests" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Latency Decomposition & Anomaly — 延迟分解与异常检测",
      "type": "row"
    },
    {
      "id": 30,
      "title": "Latency Decomposition: Model vs Framework",
      "description": "E2E 延迟分解：model_execute_time (模型推理) vs 框架开销 (调度+采样+传输)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "E2E P99 (total)"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:model_execute_time_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "Model Execute P99"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{instance=~\"$instance\"}[5m]))) - histogram_quantile(0.99, sum by (le) (rate(vllm:model_execute_time_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "Framework Overhead P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "E2E P99 (total)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Model Execute P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Framework Overhead P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 31,
      "title": "TTFT P99 Change Rate (Anomaly Detection)",
      "description": "TTFT P99 的变化速率 — 突然上升可能预示问题（如 KV Cache 满、GPU 限频）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "deriv(histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))[10m:])",
          "legendFormat": "TTFT P99 变化速率 (s/s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Histogram Heatmap — 延迟分布热力图",
      "type": "row"
    },
    {
      "id": 40,
      "title": "TTFT Histogram Heatmap",
      "description": "TTFT 延迟分布热力图 — 直观看出延迟是否在恶化、是否出现双峰分布",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[1m])) by (le)",
          "legendFormat": "{{ le }}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "unit": "s"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges"
        },
        "cellGap": 1,
        "tooltip": { "show": true }
      }
    },
    {
      "id": 41,
      "title": "TPOT Histogram Heatmap",
      "description": "TPOT 延迟分布热力图 — Decode 阶段 inter-token 延迟分布变化",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[1m])) by (le)",
          "legendFormat": "{{ le }}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "unit": "s"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Blues"
        },
        "cellGap": 1,
        "tooltip": { "show": true }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["vllm", "latency", "slo"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {},
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(vllm:time_to_first_token_seconds_bucket, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "query": "label_values(vllm:time_to_first_token_seconds_bucket, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "vLLM Latency Analysis — 延迟剖析",
  "uid": "vllm-latency",
  "version": 1
}
