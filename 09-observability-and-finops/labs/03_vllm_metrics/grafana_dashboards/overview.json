{
  "__comment": "vLLM 全局总览 Dashboard — SRE/On-call 一眼看清系统状态",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "vLLM 推理服务全局总览：吞吐、延迟、KV Cache、调度状态一览",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "iteration": 1700000000000,
  "links": [
    {
      "icon": "external link",
      "tags": ["vllm"],
      "title": "vLLM Per-Model",
      "type": "link",
      "url": "/d/vllm-per-model/vllm-per-model-analysis"
    },
    {
      "icon": "external link",
      "tags": ["vllm"],
      "title": "KV Cache Deep Dive",
      "type": "link",
      "url": "/d/vllm-kv-cache/vllm-kv-cache-analysis"
    },
    {
      "icon": "external link",
      "tags": ["vllm"],
      "title": "Latency Analysis",
      "type": "link",
      "url": "/d/vllm-latency/vllm-latency-analysis"
    }
  ],
  "panels": [
    {
      "__comment": "========== Row 1: 黄金信号 Stat Panels ==========",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Golden Signals — 黄金信号",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Generation Throughput (tokens/s)",
      "description": "集群总生成吞吐量，反映 Decode 阶段的 token 输出速率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:generation_tokens_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "title": "Prompt Throughput (tokens/s)",
      "description": "Prompt 处理吞吐量，反映 Prefill 阶段效率",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:prompt_tokens_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 500 },
              { "color": "green", "value": 2000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "TTFT P99 (s)",
      "description": "Time To First Token P99 — 用户等待第一个 token 的最坏情况",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P99 TTFT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "TPOT P99 (ms)",
      "description": "Time Per Output Token P99 — 每个 token 生成延迟的最坏情况",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P99 TPOT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Error Rate (%)",
      "description": "请求错误率 = failures / (success + failures)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:request_failure_total{instance=~\"$instance\"}[5m])) / (sum(rate(vllm:request_success_total{instance=~\"$instance\"}[5m])) + sum(rate(vllm:request_failure_total{instance=~\"$instance\"}[5m])) + 1e-10) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "KV Cache Usage (%)",
      "description": "GPU KV Cache 使用率 — 最关键的容量指标",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "KV Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "__comment": "========== Row 2: 吞吐趋势 ==========",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Throughput — 吞吐趋势",
      "type": "row"
    },
    {
      "id": 10,
      "title": "Generation Throughput (tokens/s) — 按实例",
      "description": "每个 vLLM 实例的生成吞吐量趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{ instance }}"
        },
        {
          "expr": "sum(rate(vllm:generation_tokens_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "Total (all instances)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total (all instances)" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 11,
      "title": "Request Rate (req/s) — Success vs Failure",
      "description": "成功/失败请求速率对比",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:request_success_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "Success"
        },
        {
          "expr": "sum(rate(vllm:request_failure_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "Failure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failure" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 30 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Success" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "__comment": "========== Row 3: 延迟概览 ==========",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Latency — 延迟概览",
      "type": "row"
    },
    {
      "id": 20,
      "title": "TTFT Distribution (P50 / P90 / P99)",
      "description": "Time To First Token 分位数趋势 — Prefill + Queue 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "gradientMode": "scheme"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P90" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 21,
      "title": "TPOT Distribution (P50 / P90 / P99)",
      "description": "Time Per Output Token 分位数趋势 — Decode 阶段 inter-token 延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_per_output_token_seconds_bucket{instance=~\"$instance\"}[5m]))) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "__comment": "========== Row 4: 调度 & KV Cache ==========",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Scheduling & KV Cache — 调度与缓存",
      "type": "row"
    },
    {
      "id": 30,
      "title": "Request States (Running / Waiting / Swapped)",
      "description": "请求调度状态 — Running 在 GPU 上执行, Waiting 在排队, Swapped 被换出到 CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(vllm:num_requests_running{instance=~\"$instance\"})",
          "legendFormat": "Running"
        },
        {
          "expr": "sum(vllm:num_requests_waiting{instance=~\"$instance\"})",
          "legendFormat": "Waiting"
        },
        {
          "expr": "sum(vllm:num_requests_swapped{instance=~\"$instance\"})",
          "legendFormat": "Swapped"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Running" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Waiting" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Swapped" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 31,
      "title": "KV Cache Usage (%) — GPU & CPU",
      "description": "GPU/CPU KV Cache 使用率趋势。CPU > 0 表示正在 swap，严重影响性能",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "GPU KV Cache %"
        },
        {
          "expr": "avg(vllm:cpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "CPU KV Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU KV Cache %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 32,
      "title": "Preemption Rate & Prefix Cache Hit Rate",
      "description": "Preemption 速率（越高说明 KV Cache 越紧张）& Prefix Cache 命中率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:num_preemptions_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Preemptions/s"
        },
        {
          "expr": "avg(vllm:prefix_cache_hit_rate{instance=~\"$instance\"}) * 100",
          "legendFormat": "Prefix Cache Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Preemptions/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "ops" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Prefix Cache Hit %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "percent" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 100 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "__comment": "========== Row 5: GPU 资源 ==========",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "GPU Resources — GPU 资源",
      "type": "row"
    },
    {
      "id": 40,
      "title": "GPU Memory Usage per Instance",
      "description": "每个 vLLM 实例的 GPU 显存使用量",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "vllm:gpu_memory_usage_bytes{instance=~\"$instance\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 41,
      "title": "Avg Throughput (Sliding Window)",
      "description": "vLLM 内部滑动窗口平均吞吐 — 比 rate() 更平滑",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(vllm:avg_generation_throughput_toks_per_s{instance=~\"$instance\"})",
          "legendFormat": "Generation toks/s (avg)"
        },
        {
          "expr": "sum(vllm:avg_prompt_throughput_toks_per_s{instance=~\"$instance\"})",
          "legendFormat": "Prompt toks/s (avg)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    }
