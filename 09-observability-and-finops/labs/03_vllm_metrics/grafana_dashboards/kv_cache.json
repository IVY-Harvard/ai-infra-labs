{
  "__comment": "vLLM KV Cache 深度分析 Dashboard — Cache 使用率、Preemption、Prefix Cache、Block 级分析",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "KV Cache 深度分析：使用率趋势、Preemption 关联、Prefix Cache 效率、容量预测",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "KV Cache Health — 缓存健康状态",
      "type": "row"
    },
    {
      "id": 1,
      "title": "GPU KV Cache Usage",
      "description": "GPU KV Cache 使用率。>90% 开始触发 Preemption，>95% 新请求被阻塞",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "GPU Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "CPU KV Cache Usage",
      "description": "CPU Swap 空间使用率。> 0 表示 GPU 显存不够，正在 swap 到 CPU（严重性能问题）",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:cpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "CPU Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "Prefix Cache Hit Rate",
      "description": "Prefix Cache 命中率。System prompt 复用场景应 > 80%",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:prefix_cache_hit_rate{instance=~\"$instance\"}) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Preemption Rate (per second)",
      "description": "每秒 Preemption 次数。> 0 说明 KV Cache 已满，正在抢占请求",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(vllm:num_preemptions_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Preemptions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Swapped Requests",
      "description": "当前被 swap 到 CPU 的请求数。> 0 表示 GPU 显存严重不足",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(vllm:num_requests_swapped{instance=~\"$instance\"})",
          "legendFormat": "Swapped"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Cache Pressure Index",
      "description": "Cache 压力指数 = usage × (1 + preemption_rate)。综合衡量 KV Cache 压力",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * (1 + sum(rate(vllm:num_preemptions_total{instance=~\"$instance\"}[5m])))",
          "legendFormat": "Pressure Index"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.8 },
              { "color": "orange", "value": 0.95 },
              { "color": "red", "value": 1.2 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "KV Cache Trends — 缓存趋势分析",
      "type": "row"
    },
    {
      "id": 10,
      "title": "GPU KV Cache Usage Trend (per instance)",
      "description": "每个实例的 KV Cache 使用率趋势 — 识别哪个实例最先达到容量上限",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc{instance=~\"$instance\"} * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 11,
      "title": "KV Cache Usage vs Preemption Correlation",
      "description": "KV Cache 使用率与 Preemption 速率的关联 — 验证 '使用率 > 90% → Preemption' 的因果链",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "GPU Cache Usage %"
        },
        {
          "expr": "sum(rate(vllm:num_preemptions_total{instance=~\"$instance\"}[5m])) * 100",
          "legendFormat": "Preemption Rate (×100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "GPU Cache Usage %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "percent" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Preemption Rate (×100)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.fillOpacity", "value": 25 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Prefix Cache & Block Analysis — Prefix Cache 与 Block 分析",
      "type": "row"
    },
    {
      "id": 20,
      "title": "Prefix Cache Hit Rate Trend",
      "description": "Prefix Cache 命中率趋势 — 突然下降可能意味着 cache 被大量驱逐",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "vllm:prefix_cache_hit_rate{instance=~\"$instance\"} * 100",
          "legendFormat": "{{ instance }}"
        },
        {
          "expr": "avg(vllm:prefix_cache_hit_rate{instance=~\"$instance\"}) * 100",
          "legendFormat": "Avg (all instances)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Avg (all instances)" },
            "properties": [
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "last"] }
      }
    },
    {
      "id": 21,
      "title": "GPU Blocks: Used vs Total",
      "description": "KV Cache Block 级使用情况 — 剩余 Block 数决定能接受多少新请求",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(vllm:num_gpu_blocks_total{instance=~\"$instance\"})",
          "legendFormat": "Total Blocks"
        },
        {
          "expr": "sum(vllm:num_gpu_blocks_used{instance=~\"$instance\"})",
          "legendFormat": "Used Blocks"
        },
        {
          "expr": "sum(vllm:num_gpu_blocks_total{instance=~\"$instance\"}) - sum(vllm:num_gpu_blocks_used{instance=~\"$instance\"})",
          "legendFormat": "Free Blocks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total Blocks" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Used Blocks" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Free Blocks" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "last"] }
      }
    },
    {
      "id": 22,
      "title": "Prefix Cache Savings (estimated tokens/s)",
      "description": "Prefix Cache 节省的重复计算量估算 = hit_rate × prompt_throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:prefix_cache_hit_rate{instance=~\"$instance\"}) * sum(rate(vllm:prompt_tokens_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Saved Computation (toks/s)"
        },
        {
          "expr": "sum(rate(vllm:prompt_tokens_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Total Prompt Throughput"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "tokens/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Saved Computation (toks/s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Prompt Throughput" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Capacity Forecast — 容量预测",
      "type": "row"
    },
    {
      "id": 30,
      "title": "KV Cache Usage Forecast (1h ahead)",
      "description": "基于线性外推预测 1 小时后的 KV Cache 使用率 — 提前预警容量瓶颈",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "Current Usage %"
        },
        {
          "expr": "predict_linear(avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"})[30m:], 3600) * 100",
          "legendFormat": "Predicted (1h ahead)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 110,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 90 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Predicted (1h ahead)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } },
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    },
    {
      "id": 31,
      "title": "KV Cache Impact Chain: Usage → Preemption → TTFT",
      "description": "关键因果链可视化：KV Cache 满 → Preemption 增加 → TTFT 飙升",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{instance=~\"$instance\"}) * 100",
          "legendFormat": "KV Cache Usage %"
        },
        {
          "expr": "sum(rate(vllm:num_preemptions_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Preemption Rate"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{instance=~\"$instance\"}[5m])))",
          "legendFormat": "TTFT P99 (s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "KV Cache Usage %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "unit", "value": "percent" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Preemption Rate" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "TTFT P99 (s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["vllm", "kv-cache", "capacity"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {},
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(vllm:gpu_cache_usage_perc, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "query": "label_values(vllm:gpu_cache_usage_perc, instance)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "vLLM KV Cache Analysis — KV Cache 深度分析",
  "uid": "vllm-kv-cache",
  "version": 1
}
